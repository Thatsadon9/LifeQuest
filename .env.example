# Neon Postgres — copy to .env and fill in your connection string.
# Get it from https://console.neon.tech → Project → Connect
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Google AI Studio — Mira AI chat
GEMINI_API_KEY=your-google-ai-studio-api-key
GEMINI_MODEL=gemini-3.1-flash-lite

# Session cookie lifetime in days (default 30)
SESSION_DAYS=30

# Optional: allowed browser origins for the API (comma-separated).
# On Vercel, deployment URLs are added automatically; set this for custom domains.
# CORS_ORIGINS=https://your-app.example

# Optional: sync API port (default 3001)
SYNC_PORT=3001

# Optional: client API base URL (default /api — proxied by Vite in dev)
# VITE_SYNC_API_URL=/api

# Optional: Neon project id (for MCP / docs reference)
NEON_PROJECT_ID=your-project-id
