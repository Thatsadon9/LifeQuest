# Neon Postgres — copy to .env and fill in your connection string.
# Get it from https://console.neon.tech → Project → Connect
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Google AI Studio — Mira AI chat
GEMINI_API_KEY=your-google-ai-studio-api-key
GEMINI_MODEL=gemini-3.1-flash-lite

# API auth — use the same secret on server and client (required in production).
# Generate with: openssl rand -hex 32
LIFEQUEST_API_SECRET=change-me-to-a-long-random-secret
VITE_LIFEQUEST_API_SECRET=change-me-to-a-long-random-secret

# Optional: allowed browser origins for the sync API (comma-separated).
# CORS_ORIGINS=http://localhost:5173,https://your-app.example

# Optional: sync API port (default 3001)
SYNC_PORT=3001

# Optional: client API base URL (default /api — proxied by Vite in dev)
# VITE_SYNC_API_URL=/api

# Optional: Neon project id (for MCP / docs reference)
NEON_PROJECT_ID=your-project-id
